{
  "name": "08 - Vitrine IA Flow - Infrastructure Heartbeat",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 1
            }
          ]
        }
      },
      "name": "Heartbeat a cada minuto",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [100, 240]
    },
    {
      "parameters": {
        "url": "={{$env.VITRINE_MASTER_HEALTH_URL}}",
        "options": {
          "timeout": 10000
        }
      },
      "name": "Verificar Mission Control API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [360, 240]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.VITRINE_MASTER_API_URL}}/flow/events/callback",
        "sendHeaders": true,
        "sendBody": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{$env.VITRINE_MASTER_API_TOKEN}}"
            },
            {
              "name": "X-Vitrine-Event",
              "value": "HEARTBEAT_REPORTED"
            }
          ]
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "event",
              "value": "HEARTBEAT_REPORTED"
            },
            {
              "name": "payload",
              "value": "={{ { service: 'mission_control_api', status: 'healthy', checked_at: $now } }}"
            }
          ]
        }
      },
      "name": "Reportar heartbeat",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [620, 240]
    }
  ],
  "connections": {
    "Heartbeat a cada minuto": {
      "main": [[{ "node": "Verificar Mission Control API", "type": "main", "index": 0 }]]
    },
    "Verificar Mission Control API": {
      "main": [[{ "node": "Reportar heartbeat", "type": "main", "index": 0 }]]
    }
  },
  "active": false,
  "settings": {}
}
